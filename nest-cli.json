{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "notification/template/templates/**/*.hbs",
        "outDir": "dist"
      }
    ],
    "watchAssets": true

  }
}
